---
// Add your projects here when ready
const projects: {
  title: string;
  description: string;
  tags: string[];
  href?: string;
}[] = [
  // Example (uncomment and edit):
  // {
  //   title: 'Project Name',
  //   description: 'A short description of what this project does.',
  //   tags: ['Python', 'Optimization'],
  //   href: 'https://github.com/WUUUYT/project-name',
  // },
];
---

<section id="projects">
  <div class="container">
    <p class="section-title">Projects</p>

    {projects.length > 0 ? (
      <div class="projects-grid">
        {projects.map(project => (
          <div class="project-card">
            <div class="card-inner">
              <h3 class="card-title">
                {project.href ? (
                  <a href={project.href} target="_blank" rel="noopener">{project.title}</a>
                ) : (
                  project.title
                )}
              </h3>
              <p class="card-desc">{project.description}</p>
              <div class="card-tags">
                {project.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="placeholder-grid">
        <div class="placeholder-card">
          <span class="placeholder-label">Coming Soon</span>
          <p class="placeholder-text">Projects will appear here.</p>
        </div>
        <div class="placeholder-card">
          <span class="placeholder-label">Coming Soon</span>
          <p class="placeholder-text">Stay tuned.</p>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  section {
    border-bottom: 1px solid var(--border);
  }

  .projects-grid,
  .placeholder-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  /* Real project cards */
  .project-card {
    background: var(--surface);
    transition: background 0.15s ease;
  }

  .project-card:hover {
    background: var(--surface-2);
  }

  .card-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    height: 100%;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
  }

  .card-title a {
    color: var(--text);
  }

  .card-title a:hover {
    color: var(--accent);
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 0.2em 0.55em;
    border-radius: 99px;
    font-family: var(--font-mono);
  }

  /* Placeholder cards */
  .placeholder-card {
    background: var(--surface);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.5rem;
    min-height: 140px;
  }

  .placeholder-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--border);
    border: 1px dashed var(--border);
    padding: 0.25em 0.75em;
    border-radius: 99px;
  }

  .placeholder-text {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  @media (max-width: 540px) {
    .projects-grid,
    .placeholder-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
