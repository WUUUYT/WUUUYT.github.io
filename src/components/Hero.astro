---
---

<section class="hero" id="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="avatar-wrap">
        <img src="/uploads/avatar.png" alt="WUUUYT avatar" class="avatar" />
      </div>
      <div class="hero-content">
        <p class="greeting">Hi, I'm</p>
        <h1 class="name">Yitong Wu</h1>
        <p class="tagline">
          Studying Machine Learning, RecSys &amp; LLM.<br />
          <span class="sub">Sharing ideas on math, code, and something about life.</span>
        </p>
        <div class="cta-row">
          <a href="/blog" class="btn btn-primary">View Blog</a>
          <a href="https://github.com/WUUUYT" target="_blank" rel="noopener" class="btn btn-ghost">
            GitHub
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - var(--nav-h));
    display: flex;
    align-items: center;
    padding: 2rem 0 10rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .avatar-wrap {
    flex-shrink: 0;
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid var(--border);
    object-fit: cover;
  }

  .greeting {
    font-size: 0.9375rem;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }

  .name {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.2;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-dim) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-dim);
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .sub {
    color: var(--muted);
    font-size: 0.9375rem;
  }

  .cta-row {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.15s ease;
    font-family: var(--font-sans);
    cursor: pointer;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--btn-text);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: var(--btn-text);
  }

  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text-dim);
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 540px) {
    .hero-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .avatar {
      width: 72px;
      height: 72px;
    }
  }
</style>
