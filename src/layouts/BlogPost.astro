---
import Layout from './Layout.astro';
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  date: Date;
  description?: string;
  categories?: string[];
}

const { title, date, description, categories = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={description}>
  <article class="container post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {categories.length > 0 && (
          <span class="divider">·</span>
          <span class="categories">{categories.join(' / ')}</span>
        )}
      </div>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-desc">{description}</p>}
    </header>
    <div class="post-body">
      <slot />
    </div>
    <div class="post-back">
      <a href="/blog">← All posts</a>
    </div>
  </article>
</Layout>

<style>
  .post {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    font-size: 0.8125rem;
    color: var(--muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .divider {
    color: var(--border);
  }

  .post-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .post-desc {
    color: var(--text-dim);
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  /* Post body typography */
  .post-body {
    color: var(--text-dim);
    font-size: 1rem;
    line-height: 1.8;
  }

  .post-body :global(h2) {
    font-size: 1.35rem;
    color: var(--text);
    margin: 2.5rem 0 1rem;
  }

  .post-body :global(h3) {
    font-size: 1.1rem;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-dim);
    font-style: italic;
  }

  .post-body :global(img) {
    border-radius: var(--radius-lg);
    margin: 1.5rem auto;
    max-width: 100%;
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.5rem 0;
  }

  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--border);
    padding: 0.6rem 0.875rem;
    text-align: left;
  }

  .post-body :global(th) {
    background: var(--surface-2);
    color: var(--text);
    font-weight: 600;
  }

  .post-back {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .post-back a {
    font-size: 0.875rem;
    color: var(--text-dim);
    transition: color 0.15s;
  }

  .post-back a:hover {
    color: var(--accent);
  }
</style>
